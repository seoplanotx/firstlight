{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OncoWatch",
  "version": "0.1.0",
  "identifier": "ai.oncowatch.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OncoWatch",
        "width": 1360,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "../../../dist-sidecar/oncowatch-backend"
    ]
  }
}
