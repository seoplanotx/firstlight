{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Firstlight",
  "version": "0.1.0",
  "identifier": "ai.oncowatch.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Firstlight",
        "width": 1360,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:17845 http://localhost:17845 tauri: ipc:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "nsis"
    ],
    "externalBin": [
      "../../../dist-sidecar/oncowatch-backend"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEREUyNzNGRUMxQjY2MEEKUldRS1podnNQeWZlN1RRK3EzUXBRamF0YVNpcmRpVnZEcEx2OGhkUGlWZWtpUy9Dd2ZOViszbVkK",
      "endpoints": [
        "https://github.com/seoplanotx/OncoWatch/releases/latest/download/latest.json"
      ]
    }
  }
}
